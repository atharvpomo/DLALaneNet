# =========================================================================
# PURE DLA on Orin (no GPU fallback). This build (TensorRT 8.6.13) has:
#   --useDLA  --inputIOFormats  --outputIOFormats  --half2  --int8  --calib
# It does NOT have: --useSafeDLA, --dlaLayerConfig, --allowGPUFallback.
# "Reformat CopyNode for Input Tensor 0" = FP32->FP16/chw->chw16 I/O conversion
# at the network boundary (NOT a model layer; Conv_0..Conv_71 already on DLA).
# Fix = make the I/O match DLA's native format so no reformat is inserted.
# =========================================================================

# Valid fmt tokens (TRT 8.6): chw chw2 chw4 hwc8 chw16 chw32 dhwc8 cdhw32 hwc dla_linear dla_hwc4
# DLA-only layouts: chw16, dla_linear, dla_hwc4. type must be fp16 for DLA.

# STEP 1A — DLA-native row-major I/O (worked on TRT 8.6 per NVIDIA issue #3265).
cd /home/benchdev2
/usr/local/driveworks/tools/dnn/tensorRT_optimization \
  --modelType=onnx \
  --onnxFile=/home/benchdev2/dla_lanenet_latest.onnx \
  --out=/home/benchdev2/dla_lanenet.engine \
  --useDLA=1 \
  --inputIOFormats=fp16:dla_linear \
  --outputIOFormats=fp16:dla_linear \
  --verbose=1 2>&1 | tee /home/benchdev2/dla_io.log

